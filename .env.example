# ==============================================================================
# AynuKids Backend Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# Your Supabase Project URL (found in Project Settings -> API)
SUPABASE_URL="https://YOUR-PROJECT-ID.supabase.co"

# Your Supabase Service Role Key (found in Project Settings -> API)
# WARNING: NEVER SHARE THIS KEY. It bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5..."

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# The TikTok handle you want to scrape (without the @ symbol)
TIKTOK_HANDLE="aynukids"

# Scraping settings
LOG_LEVEL="INFO"
REQUEST_DELAY_MIN="2.0"
REQUEST_DELAY_MAX="5.0"
MAX_VIDEOS_PER_RUN="0" # 0 means unlimited

# Providers to use
# Currently only "ytdlp" is fully implemented and free
CHANNEL_PROVIDER="ytdlp"
SOUND_PROVIDER="ytdlp"
